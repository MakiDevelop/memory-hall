# memory-hall — example environment

# Server
MH_HOST=0.0.0.0
MH_PORT=9000

# Storage
MH_SQLITE_PATH=./data/memory_hall.db

# Vector store: sqlite-vec (default, embedded) | qdrant
MH_VECTOR_STORE=sqlite-vec
# If qdrant:
# MH_QDRANT_URL=http://localhost:6333
# MH_QDRANT_COLLECTION=memory_hall_v0

# Embedder: ollama (default) | openai | sentence-transformers
MH_EMBEDDER=ollama
MH_EMBEDDER_MODEL=bge-m3
MH_EMBEDDER_DIM=1024
# If ollama:
MH_OLLAMA_BASE=http://localhost:11434
# If openai:
# OPENAI_API_KEY=sk-...
# MH_OPENAI_MODEL=text-embedding-3-small

# Auth
MH_HMAC_KEYS_PATH=./data/keys.json
MH_DEFAULT_TENANT=default

# Logging
MH_LOG_LEVEL=INFO
